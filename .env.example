# Greystone Trading Platform - Environment Configuration
# Copy this to .env and fill in your values

# Alpaca API (Paper Trading - https://app.alpaca.markets/paper/dashboard/overview)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER_MODE=true

# Supabase (https://supabase.com/dashboard)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Questrade API (Canadian equities - TSX/TSXV execution)
# Get API key at https://www.questrade.com/api/documentation/getting-started
# Generate a refresh token from your Questrade app hub
QUESTRADE_REFRESH_TOKEN=
QUESTRADE_ACCOUNT_ID=
QUESTRADE_MAX_ORDER_QTY=1000

# Interactive Brokers Web API (International markets, futures, forex, data feeds)
# Requires IB Gateway or TWS running locally - https://www.interactivebrokers.com/campus/ibkr-api-page/
IBKR_GATEWAY_URL=https://localhost:5000/v1/api
IBKR_ACCOUNT_ID=
IBKR_MAX_ORDER_QTY=1000

# BigData.com API (Premium institutional data)
BIGDATA_API_KEY=

# Server
PORT=3000

# Safety guardrails (Alpaca)
MAX_ORDER_QTY=1000
