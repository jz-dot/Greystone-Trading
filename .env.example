# Greystone Trading Platform - Environment Configuration
# Copy this to .env and fill in your values

# Alpaca API (Paper Trading - https://app.alpaca.markets/paper/dashboard/overview)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER_MODE=true

# Supabase (https://supabase.com/dashboard)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Questrade API (Canadian equities - TSX/TSXV execution)
# Get API key at https://www.questrade.com/api/documentation/getting-started
# Generate a refresh token from your Questrade app hub
QUESTRADE_REFRESH_TOKEN=
QUESTRADE_ACCOUNT_ID=
QUESTRADE_MAX_ORDER_QTY=1000

# Interactive Brokers Web API (International markets, futures, forex, data feeds)
# Requires IB Gateway or TWS running locally - https://www.interactivebrokers.com/campus/ibkr-api-page/
IBKR_GATEWAY_URL=https://localhost:5000/v1/api
IBKR_ACCOUNT_ID=
IBKR_MAX_ORDER_QTY=1000

# BigData.com API (Premium institutional data)
BIGDATA_API_KEY=

# Grey Sankore AI (Anthropic API - https://console.anthropic.com/)
# Server fallback key used for guests / preview. Authenticated users can bring
# their own key, which is stored encrypted per-user (see MASTER_KEY below).
ANTHROPIC_API_KEY=

# Master encryption key for at-rest encryption of per-user API credentials
# stored in Supabase (api_credentials), using AES-256-GCM. Provide 32 bytes as
# 64 hex chars or base64. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, per-user credentials are stored WITHOUT encryption (a warning is
# logged). Set this in any real deployment.
MASTER_KEY=

# Server
PORT=3000

# CORS allowlist (comma-separated origins allowed to call the API cross-origin).
# Leave empty for same-origin only (the co-hosted frontend still works).
# Example: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=

# Order safety guardrails (all brokers)
# Max share/contract quantity per order, and max dollar notional per order.
MAX_ORDER_QTY=1000
MAX_ORDER_NOTIONAL=50000

# Live-trading server-side gates. IBKR and Questrade order placement is blocked
# unless explicitly enabled here. Alpaca live mode is gated by ALPACA_PAPER_MODE.
IBKR_LIVE_TRADING=false
QUESTRADE_LIVE_TRADING=false
