# Greystone Trading Platform - Environment Configuration
# Copy this to .env and fill in your values

# Alpaca API (Paper Trading - https://app.alpaca.markets/paper/dashboard/overview)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER_MODE=true

# Server
PORT=3000

# Safety guardrails
MAX_ORDER_QTY=1000
