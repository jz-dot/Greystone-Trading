# Greystone Trading Platform - Environment Configuration
# Copy this to .env and fill in your values

# Alpaca API (Paper Trading - https://app.alpaca.markets/paper/dashboard/overview)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER_MODE=true

# Supabase (https://supabase.com/dashboard)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# BigData.com API (Premium institutional data)
BIGDATA_API_KEY=

# Server
PORT=3000

# Safety guardrails
MAX_ORDER_QTY=1000
