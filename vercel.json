{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bash build-static.sh",
  "outputDirectory": ".static",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "framework": null
}